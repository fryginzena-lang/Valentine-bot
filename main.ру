from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import CommandStart, Command
from aiogram.utils.keyboard import InlineKeyboardBuilder, ReplyKeyboardBuilder

TOKEN = "8658498466:AAHKLcqwKkclLdlytYNGM_vobIjx7KzMWJY"

bot = Bot(token=TOKEN)
dp = Dispatcher()
user_status = {} 

# Функция для создания главного меню (кнопки внизу)
def main_menu():
    builder = ReplyKeyboardBuilder()
    builder.button(text="🔗 Моя ссылка")
    builder.button(text="👤 Профиль")
    return builder.as_markup(resize_keyboard=True)

@dp.message(CommandStart())
async def start(message: types.Message):
    args = message.text.split()
    if len(args) > 1:
        target_id = args[1]
        user_status[message.from_user.id] = f"sending:{target_id}"
        await message.answer("🤫 Напишите анонимное сообщение:", reply_markup=types.ReplyKeyboardRemove())
    else:
        await message.answer("Добро пожаловать! Используйте меню ниже 👇", reply_markup=main_menu())

@dp.message(F.text == "👤 Профиль")
async def profile(message: types.Message):
    text = (f"👤 *Ваш Профиль*\n\n🆔 ID: `{message.from_user.id}`\n🌟 Статус: Обычный")
    await message.answer(text, parse_mode="Markdown")

@dp.message(F.text == "🔗 Моя ссылка")
async def my_link(message: types.Message):
    bot_info = await bot.get_me()
    link = f"https://t.me/{bot_info.username}?start={message.from_user.id}"
    await message.answer(f"🚀 Ваша ссылка:\n\n`{link}`", parse_mode="Markdown")

@dp.message(F.text)
async def handle_message(message: types.Message):
    user_id = message.from_user.id
    if user_id in user_status and user_status[user_id].startswith("sending:"):
        target_id = user_status[user_id].split(":")[1]
        
        # Кнопки под анонимным сообщением
        builder = InlineKeyboardBuilder()
        builder.row(types.InlineKeyboardButton(text="💬 Ответить", callback_data=f"reply:{user_id}"))
        builder.row(types.InlineKeyboardButton(text="🔍 Кто это?", callback_data="premium_info"))

        try:
            await bot.send_message(
                target_id, 
                f"📩 *Новое анонимное сообщение:*\n\n{message.text}",
                reply_markup=builder.as_markup(),
                parse_mode="Markdown"
            )
            await message.answer("✅ Отправлено!", reply_markup=main_menu())
            del user_status[user_id]
        except Exception:
            await message.answer("❌ Ошибка отправки.", reply_markup=main_menu())
    else:
        await message.answer("Воспользуйтесь меню:", reply_markup=main_menu())

@dp.callback_query(F.data == "premium_info")
async def premium_call(callback: types.CallbackQuery):
    await callback.answer("Функция доступна в Premium!", show_alert=True)

@dp.callback_query(F.data.startswith("reply:"))
async def reply_call(callback: types.CallbackQuery):
    target_id = callback.data.split(":")[1]
    user_status[callback.from_user.id] = f"sending:{target_id}"
    await callback.message.answer("🤫 Напишите анонимный ответ:")
    await callback.answer()

async def main():
    await dp.start_polling(bot)

if __name__ == "__main__":
keep_alive(); 
    asyncio.run(main())
